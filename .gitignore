## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
build/
bin/
obj/
out/

# Visual Studio cache/options directory
.vs/

# Rider
.idea/

# VS Code
.vscode/

# Logs
*.log

# NuGet
*.nupkg
packages/
!packages/build/
*.snupkg

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Entity Framework
*.mdf
*.ldf

# IIS Express
iisexpress/
.vs/config/

# Publish output
publish/
wwwroot/dist/

# Azure
PublishScripts/

# Test Results
TestResults/
*.trx

# Resharper
_ReSharper*/
*.[Rr]e[Ss]harper

# DotCover
*.dotCover

# SQL Server files
*.mdf
*.ldf

# Windows image file caches
Thumbs.db
ehthumbs.db

# macOS
.DS_Store

# Environment variables
.env
.env.*

# Node modules (if frontend included)
node_modules/

# npm logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Docker
docker-compose.override.yml

# Coverage reports
coverage/
*.coverage
*.coveragexml

# Temporary files
*.tmp
*.temp

# JetBrains Rider
*.sln.iml